    "judgment_rules": {
      "title": "寻物吉凶判断",
      "rules": [
        {
          "condition": "用神宫遇生门、开门、休门",
          "result": "吉",
          "meaning": "容易找到，物品保存完好"
        },
        {
          "condition": "用神宫遇死门",
          "result": "凶",
          "meaning": "难以找到，或物品已损坏、被处理"
        },
        {
          "condition": "用神宫遇杜门",
          "result": "平",
          "meaning": "物品被藏匿，需仔细搜寻"
        },
        {
          "condition": "用神宫遇惊门",
          "result": "凶",
          "meaning": "物品可能被盗，或已被他人拿走"
        },
        {
          "condition": "用神宫遇伤门",
          "result": "凶",
          "meaning": "物品可能已损坏"
        },
        {
          "condition": "用神宫遇景门",
          "result": "平",
          "meaning": "物品在明显处，但可能被遮挡"
        },
        {
          "condition": "用神宫有值符",
          "result": "吉",
          "meaning": "贵人相助，容易找回"
        },
        {
          "condition": "用神宫有白虎",
          "result": "凶",
          "meaning": "物品可能被抢夺或丢失严重"
        },
        {
          "condition": "用神宫有玄武",
          "result": "凶",
          "meaning": "物品可能被盗，小偷所为"
        }
      ]
    },
