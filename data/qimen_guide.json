  "interpretation_steps": {
    "title": "如何解读",
    "steps": [
      "先看值符宫（最重要），代表核心问题",
      "根据所求事项看对应宫位（如求财看震宫3）",
      "观察该宫的吉凶状态（门、星、神的组合）",
