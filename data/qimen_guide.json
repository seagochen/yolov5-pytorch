{
  "introduction": {
    "title": "奇门遁甲",
    "description": "奇门遁甲是中国古代最高层次的预测学，被誉为'帝王之学'。它综合了天文、历法、阴阳五行等理论，通过时间和空间的变化来预测吉凶。"
  },
  "elements": {
    "title": "九宫格元素说明",
    "items": [
      {
        "name": "地盘（三奇六仪）",
        "description": "固定不变，代表基础因素"
      },
      {
        "name": "天盘",
        "description": "运转变化，代表动态因素"
      },
      {
        "name": "八门",
        "description": "代表人事活动（生门、死门、伤门等）"
      },
      {
        "name": "九星",
        "description": "代表天时星象（天蓬、天芮、天冲等）"
      },
      {
        "name": "八神",
        "description": "代表神煞吉凶（值符、腾蛇、太阴等）"
      }
    ]
  },
  "four_pillars": {
    "title": "四柱用神（重点）",
    "description": "四柱用神是奇门遁甲中非常重要的概念，用于判断不同人事物的状态。",
    "pillars": [
      {
        "name": "年干",
        "gong": "坎宫1",
        "meaning": "代表求测者本人、自己的想法和状态"
      },
      {
        "name": "月干",
        "gong": "震宫3",
        "meaning": "代表兄弟姐妹、同事、朋友、合作伙伴"
      },
      {
        "name": "日干",
        "gong": "乾宫6",
        "meaning": "代表父母、领导、上级、贵人、权威"
      },
      {
        "name": "时干",
        "gong": "兑宫7",
        "meaning": "代表子女、下属、晚辈、执行者"
      }
    ],
    "examples": [
      {
        "scenario": "求职",
        "pillar": "日干（乾宫6）",
        "explanation": "看领导、上级的态度"
      },
      {
        "scenario": "求财",
        "pillar": "月干（震宫3）",
        "explanation": "看合作伙伴、客户关系"
      },
      {
        "scenario": "问子女",
        "pillar": "时干（兑宫7）",
        "explanation": "看孩子的状态"
      },
      {
        "scenario": "问自己",
        "pillar": "年干（坎宫1）",
        "explanation": "看自身条件"
      }
    ]
  },
