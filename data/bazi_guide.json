      "ke": {
        "title": "相克关系",
        "description": "木克土、土克水、水克火、火克金、金克木"
      }
    },
    "balance": {
      "title": "五行平衡",
      "description": "八字中五行的数量和强弱决定了一个人的性格特征和运势倾向。五行过旺或过弱都会影响运势。",
      "ideal": "理想状态是五行相对平衡，各有所长"
    }
  },
  "shensha": {
    "title": "神煞",
    "description": "神煞是八字命理中的特殊星曜，分为吉神和凶神，用以辅助判断命运吉凶。",
    "categories": [
      {
        "type": "吉神",
        "description": "带来好运、助力的神煞",
        "examples": [
          "天德贵人：主贵人相助，逢凶化吉",
          "月德贵人：主德行高尚，受人尊敬",
          "天乙贵人：主遇难呈祥，有贵人相助",
          "文昌贵人：主聪明好学，利于功名",
          "福星贵人：主福气深厚，安康吉祥"
        ]
      },
      {
        "type": "凶神",
        "description": "带来阻碍、挑战的神煞",
        "examples": [
          "羊刃：主性格刚烈，易有血光之灾",
          "劫煞：主财运受损，易遭劫掠",
          "灾煞：主易遇灾祸，需谨慎",
          "孤辰寡宿：主孤独，人际关系淡薄",
          "亡神：主变动不安，易有损失"
        ]
      }
    ],
    "note": "神煞只是辅助判断，不可过度迷信，需结合整体八字综合分析"
  },
  "calendar_systems": {
    "title": "历法说明",
    "gregorian": {
      "name": "公历",
      "description": "即阳历，现在国际通用的历法，以地球绕太阳公转为基础"
    },
    "lunar": {
      "name": "农历",
      "description": "即阴历，中国传统历法，以月亮圆缺周期为基础，结合节气调整",
      "note": "八字排盘通常使用农历，但需注意节气才是真正的分界点"
    },
    "solar_terms": {
      "name": "节气",
      "description": "一年24节气，是八字排盘月柱划分的依据",
      "importance": "月柱以节气为界，而非农历月份"
    }
  },
  "usage_tips": {
    "title": "使用建议",
    "tips": [
      "输入准确的出生时间：时辰对八字影响很大，尽量精确到分钟",
      "了解时区差异：如在国外出生，需转换为北京时间（东八区）",
      "节气分界：月柱以节气为界，立春前后出生需特别注意",
      "综合分析：不要单看某一柱或某一神煞，需整体把握",
      "理性对待：八字是参考，不是宿命，后天努力同样重要"
    ]
  }
}
