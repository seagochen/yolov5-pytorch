{
  "introduction": {
    "title": "八字排盘",
    "description": "八字，又称四柱八字，是中国传统命理学的重要组成部分。通过出生的年、月、日、时推算出天干地支，共八个字，用以分析人的命运、性格、运势等。"
  },
  "pillars": {
    "title": "四柱说明",
    "description": "四柱即年柱、月柱、日柱、时柱，每柱由一个天干和一个地支组成。",
    "items": [
      {
        "name": "年柱",
        "description": "代表祖上、父母、童年及16岁前的运势",
        "composition": "出生年份的干支"
      },
      {
        "name": "月柱",
        "description": "代表兄弟姐妹、父母、青年及17-32岁的运势",
        "composition": "出生月份的干支"
      },
      {
        "name": "日柱",
        "description": "代表自己和配偶、中年及33-48岁的运势，最为重要",
        "composition": "出生日期的干支"
      },
      {
        "name": "时柱",
        "description": "代表子女、晚年及49岁后的运势",
        "composition": "出生时辰的干支"
      }
    ]
  },
